<Window x:Class="C_FTS.Controller.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:C_FTS.Controller"
        mc:Ignorable="d"
        Title="Login" Height="400" Width="600">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Height="276" Width="452">
            <TextBlock Text="Festival Ticketing App"
                       FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0 0 0 8"/>
            <TextBlock Text="Login"
                       FontSize="16"
                       HorizontalAlignment="Center" Margin="0 0 0 16"/>
            <TextBox x:Name="username"
                     Margin="20 20 20 10"
                     KeyDown="IfIsEnterUsername"/>
            <PasswordBox x:Name="password"
                         Margin="20 10 20 20"
                         KeyDown="IfIsEnterPassword"/>
            <Button x:Name="loginButton"
                    Content="Login"
                    HorizontalAlignment="Center"
                    Padding="10 0 10 10"
                    Click="LoginBtn"/>
        </StackPanel>
    </Grid>
</Window>