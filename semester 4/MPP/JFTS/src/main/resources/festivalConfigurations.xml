<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- PERSISTENCE -->
    <bean id="database" class="ro.mpp.utils.Database" scope="prototype"/>

    <bean id="userDBRepository" class="ro.mpp.repository.DBRepository.UserRepository">
        <constructor-arg ref="database"/>
    </bean>

    <bean id="venueDBRepository" class="ro.mpp.repository.DBRepository.VenueRepository">
        <constructor-arg ref="database"/>
    </bean>

    <bean id="artistDBRepository" class="ro.mpp.repository.DBRepository.ArtistRepository">
        <constructor-arg ref="database"/>
    </bean>

    <bean id="showDBRepository" class="ro.mpp.repository.DBRepository.ShowRepository">
        <constructor-arg ref="database" index="0"/>
        <constructor-arg ref="venueDBRepository" index="1"/>
    </bean>

    <bean id="ticketValidator" class="ro.mpp.validator.TicketValidator"/>

    <bean id="ticketDBRepository" class="ro.mpp.repository.DBRepository.TicketRepository">
        <constructor-arg ref="database" index="0"/>
        <constructor-arg ref="showDBRepository" index="1"/>
        <constructor-arg ref="ticketValidator" index="2"/>
    </bean>

    <bean id="showArtistDBRepository" class="ro.mpp.repository.DBRepository.ShowArtistRepository">
        <constructor-arg ref="database" index="0"/>
        <constructor-arg ref="artistDBRepository" index="1"/>
        <constructor-arg ref="showDBRepository" index="2"/>
    </bean>

    <!-- SERVICE -->
    <bean id="authenticator" class="ro.mpp.authenticator.Authenticator">
        <constructor-arg ref="userDBRepository"/>
    </bean>

    <bean id="festivalService" class="ro.mpp.service.FestivalService">
        <constructor-arg ref="artistDBRepository"/>
        <constructor-arg ref="venueDBRepository"/>
        <constructor-arg ref="showDBRepository"/>
        <constructor-arg ref="ticketDBRepository"/>
        <constructor-arg ref="showArtistDBRepository"/>
    </bean>

    <!-- CONTROLLER -->
    <bean id="loginController" class="ro.mpp.controller.LoginController">
        <property name="authenticator" ref="authenticator"/>
        <property name="festivalService" ref="festivalService"/>
    </bean>
</beans>