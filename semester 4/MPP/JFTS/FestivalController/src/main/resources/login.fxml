<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" styleClass="root" stylesheets="@login.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ro.mpp.controller.LoginController">
    <VBox alignment="CENTER" layoutX="14.0" layoutY="14.0" prefHeight="376.0" prefWidth="576.0" styleClass="container" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="14.0">
        <Label styleClass="title" text="Festival Ticketing App" />
        <Label styleClass="subtitle" text="Login" />
        <TextField fx:id="username" onKeyPressed="#ifIsEnterUsername" promptText="Username" styleClass="input">
         <VBox.margin>
            <Insets bottom="10.0" left="20.0" right="20.0" top="20.0" />
         </VBox.margin></TextField>
        <PasswordField fx:id="password" onKeyPressed="#ifIsEnterPassword" promptText="Password" styleClass="input">
         <VBox.margin>
            <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
         </VBox.margin></PasswordField>
        <Button fx:id="loginButton" mnemonicParsing="false" onAction="#login" styleClass="login-button" text="Login">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" />
         </padding></Button>
    </VBox>
</AnchorPane>
