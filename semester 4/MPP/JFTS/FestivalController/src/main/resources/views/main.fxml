<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="501.0" prefWidth="758.0" styleClass="root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ro.mpp.controller.MainController">
    <VBox layoutX="14.0" layoutY="14.0" styleClass="back-container" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="14.0">
        <HBox alignment="CENTER_RIGHT" prefHeight="42.0" prefWidth="571.0">
            <Label prefHeight="35.0" prefWidth="310.0" styleClass="title" text="Festival Ticketing System">
                <HBox.margin>
                    <Insets bottom="5.0" left="15.0" right="80.0" top="5.0" />
                </HBox.margin>
            </Label>
            <Button mnemonicParsing="false" onAction="#setFilterDate" text="Filter" />
            <DatePicker fx:id="datePicker">
                <HBox.margin>
                    <Insets bottom="5.0" left="5.0" right="15.0" top="5.0" />
                </HBox.margin>
            </DatePicker>
        </HBox>
        <HBox prefHeight="309.0" prefWidth="674.0">
            <TableView fx:id="fullTableView" prefHeight="164.0" prefWidth="542.0">
                <columns>
                    <TableColumn fx:id="fullArtistColumn" prefWidth="75.0" text="Performer" />
                    <TableColumn fx:id="fullDateColumn" prefWidth="75.0" text="Date" />
                    <TableColumn fx:id="fullVenueColumn" prefWidth="75.0" text="Venue" />
                    <TableColumn fx:id="fullAvailableSeatsColumn" prefWidth="91.99998474121094" text="Available seats" />
                    <TableColumn fx:id="fullSoldSeatsColumn" prefWidth="69.5999755859375" text="Sold seats" />
                </columns>
            </TableView>
            <TableView fx:id="filteredTableView" prefHeight="246.0" prefWidth="477.0">
                <columns>
                    <TableColumn fx:id="filteredArtistColumn" prefWidth="75.0" text="Performer" />
                    <TableColumn fx:id="filteredVenueColumn" prefWidth="75.0" text="Venue" />
                    <TableColumn fx:id="filteredFromColumn" prefWidth="75.0" text="From" />
                    <TableColumn fx:id="filteredAvailableSeatsColumn" prefWidth="94.39990234375" text="Available seats" />
                </columns>
            </TableView>
        </HBox>
        <HBox alignment="CENTER" prefHeight="235.0" prefWidth="669.0">
            <Button fx:id="sellTicketButton" mnemonicParsing="false" onAction="#sellTicketAction" prefWidth="100.0" styleClass="login-button" text="Sell">
                <HBox.margin>
                    <Insets left="10.0" right="10.0" />
                </HBox.margin>
            </Button>
            <VBox alignment="CENTER" maxHeight="141.0" prefHeight="125.0" prefWidth="218.0" styleClass="in-container">
                <TextField fx:id="buyerName" promptText="Buyer Name" styleClass="input">
                    <VBox.margin>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </VBox.margin>
                </TextField>
                <TextField fx:id="numberOfSeats" promptText="Number of Seats" styleClass="input">
                    <VBox.margin>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </VBox.margin>
                </TextField>
            <HBox.margin>
               <Insets bottom="10.0" left="10.0" right="10.0" top="20.0" />
            </HBox.margin>
            </VBox>
            <Button fx:id="modifyTicketButton" mnemonicParsing="false" onAction="#modifyTicketAction" prefWidth="100.0" styleClass="login-button" text="Modify">
                <HBox.margin>
                    <Insets left="10.0" right="10.0" />
                </HBox.margin>
            </Button>
            <VBox alignment="CENTER" maxHeight="214.0" prefHeight="150.0" prefWidth="220.0" styleClass="in-container">
                <TextField fx:id="ticketId" promptText="Ticket ID" styleClass="input">
                    <VBox.margin>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </VBox.margin>
                </TextField>
                <TextField fx:id="newNumberOfSeats" promptText="New Number of Seats" styleClass="input">
                    <VBox.margin>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </VBox.margin>
                </TextField>
            <HBox.margin>
               <Insets bottom="10.0" left="10.0" right="10.0" top="20.0" />
            </HBox.margin>
            </VBox>
        </HBox>
    </VBox>
   <stylesheets>
      <URL value="@main.css" />
      <URL value="@login.css" />
   </stylesheets>
</AnchorPane>
